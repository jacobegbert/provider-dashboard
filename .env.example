# ─── REQUIRED ────────────────────────────────────────────────────────────────

# MySQL connection string (Railway provides this automatically as ${{MySQL.DATABASE_URL}})
DATABASE_URL=mysql://user:password@host:3306/dbname

# Secret key for signing JWT session cookies — use a long random string
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-here

# Your login email (used to auto-assign admin role on first login)
OWNER_EMAIL=jacobegbert@gmail.com

# Anthropic API key for AI features (AI Advisor, protocol suggestions, etc.)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── EMAIL (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=notifications@blacklabelmedicine.com

# ─── SMS (Twilio) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ─── FILE STORAGE (AWS S3) ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET_NAME=black-label-medicine

# ─── GOOGLE CALENDAR ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# ─── GOOGLE MAPS (optional — for location features) ──────────────────────────
GOOGLE_MAPS_API_KEY=...
